# infra-backup config example

BASE="${BASE:-${INFRA_BACKUP_BASE:-$HOME/infra-backup}}"

CONFIG_DIR="$BASE/config"
SCRIPT_DIR="$BASE/scripts"
LOG_DIR="$BASE/logs"
LOCAL_BACKUP_DIR="$BASE/local-backups"
RESTORE_DIR="$BASE/restore"

OPENWRT_HOST="root@openwrt.lan"
OPENWRT_REMOTE_DIR="/root/infra-backup"
OPENWRT_LOCAL_DIR="$LOCAL_BACKUP_DIR/openwrt"

NETWORK_CONF_DIR="${NETWORK_CONF_DIR:-$HOME/network}"
CADDY_CONF="${CADDY_CONF:-$HOME/caddy/Caddyfile}"

CONTAINER_COPY_DIRS="
adguardhome:/opt/adguardhome/conf|$NETWORK_CONF_DIR/adguard/conf
wg-easy:/etc/wireguard|$NETWORK_CONF_DIR/wg-easy/data
"

BACKUP_PATHS="
$HOME/docker-compose.yml
$HOME/.env
$HOME/.cloudflared
$HOME/ha/Dockerfile.ha
$HOME/ha/config/configuration.yaml
$HOME/ha/config/secrets.yaml
$HOME/ha/config/automations.yaml
$HOME/ha/config/scripts.yaml
$HOME/ha/config/scenes.yaml
$HOME/ha/config/backups
$HOME/mosquitto/config
$HOME/mosquitto/data
$HOME/zigbee2mqtt/data/configuration.yaml
$HOME/zigbee2mqtt/data/coordinator_backup.json
$HOME/zigbee2mqtt/data/database.db
$HOME/zigbee2mqtt/data/state.json
$HOME/zigbee2mqtt/data/external_converters
$HOME/.ddns-go/.ddns_go_config.yaml
$HOME/filebrowser/config
$HOME/filebrowser/database
$HOME/uptime-kuma/db-config.json
$HOME/uptime-kuma/kuma.db
$NETWORK_CONF_DIR/.env
$NETWORK_CONF_DIR/docker-compose.yml
$NETWORK_CONF_DIR/adguard/conf
$NETWORK_CONF_DIR/wg-easy/data
$NETWORK_CONF_DIR/mihomo/config/config.yaml
$NETWORK_CONF_DIR/mihomo/config/proxies
$NETWORK_CONF_DIR/mihomo/config/rules
$CADDY_CONF
/etc/systemd/system/mihomo-gateway.service
/etc/systemd/system/mihomo-tproxy-route.service
/etc/systemd/system/docker.service.d/proxy.conf
/etc/crontab
/etc/cron.d
/usr/local/bin/mihomo-gateway.sh
/usr/local/bin/mihomo-tproxy-route.sh
"

BACKUP_SCAN_ROOTS="$HOME /usr/local/bin /etc/systemd/system"

EXCLUDE_PATHS="
*.log
*.tmp
*.cache
*.bak
*.backup
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.pyc
/cache/
/.cache/
/__pycache__/
/node_modules/
/.git/
$HOME/network/mihomo/config/Country.mmdb
$HOME/network/mihomo/config/GeoIP.dat
$HOME/network/mihomo/config/GeoSite.dat
$HOME/network/mihomo/config/cache.db
$HOME/network/mihomo/config/geoip.metadb
$BASE/logs/*
$BASE/local-backups/*
"

KEEP_LOCAL_OPENWRT=3
KEEP_LOCAL_PI=3

KEEP_DAILY=3
KEEP_WEEKLY=1
KEEP_MONTHLY=1

RESTIC_ENV="$HOME/.restic-r2-env"
RESTIC_TAG="infra-backup"
