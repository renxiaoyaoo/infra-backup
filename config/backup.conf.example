# infra-backup config example

BASE="${BASE:-${INFRA_BACKUP_BASE:-$HOME/infra-backup}}"

CONFIG_DIR="$BASE/config"
SCRIPT_DIR="$BASE/scripts"
LOG_DIR="$BASE/logs"
LOCAL_BACKUP_DIR="$BASE/local-backups"
RESTORE_DIR="$BASE/restore"

OPENWRT_HOST="root@openwrt.lan"
OPENWRT_REMOTE_DIR="/root/infra-backup"
OPENWRT_LOCAL_DIR="$LOCAL_BACKUP_DIR/openwrt"

BACKUP_PATHS="
$HOME/raspberry-conf/docker-compose.yml
$HOME/raspberry-conf/.env
$HOME/raspberry-conf/ha/Dockerfile.ha
$HOME/raspberry-conf/ha/config/configuration.yaml
$HOME/raspberry-conf/mosquitto/config
$HOME/raspberry-conf/zigbee2mqtt/data/configuration.yaml
$HOME/raspberry-conf/zigbee2mqtt/data/coordinator_backup.json
$HOME/raspberry-conf/zigbee2mqtt/data/database.db
$HOME/raspberry-conf/zigbee2mqtt/data/state.json
$HOME/raspberry-conf/zigbee2mqtt/data/external_converters
$HOME/.ddns-go/.ddns_go_config.yaml
$HOME/network/docker-compose.yml
$HOME/network/mihomo/config/config.yaml
$HOME/network/mihomo/config/proxies
$HOME/network/mihomo/config/rules
$HOME/caddy/Caddyfile
/etc/systemd/system/mihomo-gateway.service
/etc/systemd/system/mihomo-tproxy-route.service
/etc/systemd/system/docker.service.d/proxy.conf
/etc/crontab
/etc/cron.d
/usr/local/bin/mihomo-gateway.sh
/usr/local/bin/mihomo-tproxy-route.sh
"

BACKUP_SCAN_ROOTS="$HOME /usr/local/bin /etc/systemd/system"

EXCLUDE_PATHS="
*.log
*.tmp
*.cache
*.bak
*.backup
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.pyc
/cache/
/.cache/
/__pycache__/
/node_modules/
/.git/
$HOME/network/mihomo/config/Country.mmdb
$HOME/network/mihomo/config/GeoIP.dat
$HOME/network/mihomo/config/GeoSite.dat
$HOME/network/mihomo/config/cache.db
$HOME/network/mihomo/config/geoip.metadb
$BASE/logs/*
$BASE/local-backups/*
"

KEEP_LOCAL_OPENWRT=3
KEEP_LOCAL_PI=3

KEEP_DAILY=3
KEEP_WEEKLY=1
KEEP_MONTHLY=1

RESTIC_ENV="$HOME/.restic-r2-env"
RESTIC_TAG="infra-backup"
